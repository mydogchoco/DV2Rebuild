# Godot import cache / exports
.godot/
/export/
/build/
*.tmp
*.translation

# Local saves (gitignored per CLAUDE.md)
/saves/

# Raw assets — live in their own repo (DV2/, ~579MB). Not committed here.
/DV2/

# Converted assets can be regenerated by scripts/tools — keep out of git
/assets/converted/*
!/assets/converted/.gitkeep

# Large wiki reference PDFs (hundreds of MB)
/docs/Wiki/*.pdf

# Python
__pycache__/
*.pyc

# Claude Code local harness settings
/.claude/

# Generated artifacts (regenerable by scripts/tools)
/scenes/dragons/
/scratch_shots/
