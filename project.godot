; Godot 4.7 project — 드래곤빌리지2 오프라인 재구현
; 자세한 설계: CLAUDE.md, docs/roadmap.md

config_version=5

[application]

config/name="DragonVillage2 Offline"
config/description="서비스 종료된 드래곤빌리지2의 개인 소장용 오프라인 재구현 (PC)"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="res://icon.svg"

[display]

; ASSUMPTION: 원작은 모바일 세로(480 baseline). PC 타깃이므로 세로형 창을 기본으로 두되 리사이즈 허용.
window/size/viewport_width=540
window/size/viewport_height=960
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
