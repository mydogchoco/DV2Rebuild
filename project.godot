; Godot 4.7 project — 드래곤빌리지2 오프라인 재구현
; 자세한 설계: CLAUDE.md, docs/roadmap.md

config_version=5

[application]

config/name="DragonVillage2 Offline"
config/description="서비스 종료된 드래곤빌리지2의 개인 소장용 오프라인 재구현 (PC)"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="res://icon.svg"
run/main_scene="res://scenes/cave.tscn"

[autoload]

Data="*res://scripts/core/data_loader.gd"
RNG="*res://scripts/core/rng.gd"
SaveSystem="*res://scripts/core/save_system.gd"

[display]

; 원작은 가로모드. PC 타깃 기준 해상도 1920x1080(16:9). 리사이즈 시 비율 유지.
window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
